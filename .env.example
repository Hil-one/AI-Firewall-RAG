# ── General ────────────────────────────────────────────────────────────────────
APP_ENV=development

# Set to True to log threats without blocking (useful for shadow-mode testing)
DRY_RUN=False

# ── Vector DB ──────────────────────────────────────────────────────────────────
# Backend: "chroma" (default) or "qdrant"
VECTOR_DB_BACKEND=chroma

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Qdrant (only needed if VECTOR_DB_BACKEND=qdrant)
# QDRANT_URL=http://localhost:6333

VECTOR_COLLECTION_NAME=malicious_signatures

# ── Detection Thresholds ───────────────────────────────────────────────────────
# Tier 1: immediately block if cosine similarity >= this value
BLOCK_THRESHOLD=0.80

# Tier 2: escalate to LLM Judge if similarity is in [ESCALATE_LOW, BLOCK_THRESHOLD)
ESCALATE_LOW=0.60

# ── LLM Judge (Tier 2) ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Timeout for LLM Judge HTTP calls (seconds)
LLM_JUDGE_TIMEOUT_SECONDS=10

# What to do when the LLM Judge is unreachable: "allow" or "block"
LLM_JUDGE_FAILSAFE=block

# ── PII Scanner (Tier 3 / Presidio) ───────────────────────────────────────────
PRESIDIO_SUPPORTED_LANGUAGES=["en"]

# Minimum Presidio confidence score to flag an entity as PII
PII_SCORE_THRESHOLD=0.70
